DEX_LLM_DEX_NAME=hyperliquid
DEX_LLM_SYMBOL=BTC
DEX_LLM_HEATMAP_SOURCE=external

DEX_LLM_LLM_PROVIDER=openai
DEX_LLM_LLM_MODEL=gpt-5.4
DEX_LLM_LLM_TIMEOUT_S=5
DEX_LLM_OPENAI_VERBOSITY=medium
DEX_LLM_OPENAI_REASONING_EFFORT=medium
DEX_LLM_OPENAI_REASONING_SUMMARY=auto
DEX_LLM_OPENAI_STORE=true
DEX_LLM_OPENAI_INCLUDE=reasoning.encrypted_content,web_search_call.action.sources

DEX_LLM_HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
DEX_LLM_HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
DEX_LLM_COINGLASS_BASE_URL=https://open-api-v4.coinglass.com
DEX_LLM_COINGLASS_HEATMAP_PATH=/api/futures/liquidation/aggregated-heatmap/model1

DEX_LLM_RISK_PER_TRADE_PCT=0.35
DEX_LLM_EXECUTION_MODE=paper
DEX_LLM_MARGIN_MODE=isolated
DEX_LLM_TARGET_LEVERAGE=10
DEX_LLM_BASE_LEVERAGE=6
DEX_LLM_MAX_LEVERAGE=10
DEX_LLM_MAX_PRICE_DEVIATION_BPS=500
DEX_LLM_CLOCK_DRIFT_LIMIT_MS=500

# 아래 값들은 직접 채워야 합니다.
#
# DEX_LLM_OPENAI_API_KEY
# - OpenAI API 대시보드에서 발급한 API 키를 넣습니다.
# - 보통 "API Keys" 화면에서 새 키를 만든 뒤 그대로 붙여 넣으면 됩니다.
DEX_LLM_OPENAI_API_KEY=

# DEX_LLM_TRADING_USER_ADDRESS
# - Hyperliquid에서 실제 주문/포지션이 잡히는 "거래 계좌 주소"를 넣습니다.
# - WS 구독, open orders 조회, fills 조회는 이 주소를 기준으로 동작합니다.
# - signer agent 주소를 여기 넣으면 조회 결과가 비거나 꼬일 수 있습니다.
DEX_LLM_TRADING_USER_ADDRESS=

# DEX_LLM_SIGNER_AGENT_ADDRESS
# - Hyperliquid에서 approveAgent로 승인한 API agent 지갑 주소를 넣습니다.
# - 아래 private key와 반드시 같은 지갑 주소여야 합니다.
DEX_LLM_SIGNER_AGENT_ADDRESS=

# DEX_LLM_SIGNER_PRIVATE_KEY
# - 위 signer agent 주소에 대응하는 private key를 넣습니다.
# - 실거래용 메인 지갑 키를 그대로 넣지 말고, agent 전용 키를 따로 쓰는 편이 안전합니다.
DEX_LLM_SIGNER_PRIVATE_KEY=

# DEX_LLM_HYPERLIQUID_VAULT_ADDRESS
# - vault/subaccount 구조로 거래할 때만 해당 vault 주소를 넣습니다.
# - 일반 개인 계정으로 직접 거래하면 비워 둬도 됩니다.
DEX_LLM_HYPERLIQUID_VAULT_ADDRESS=

# DEX_LLM_COINGLASS_API_KEY
# - CoinGlass Open API에서 발급한 API 키를 넣습니다.
# - liquidation heatmap 데이터를 가져오려면 필요합니다.
DEX_LLM_COINGLASS_API_KEY=
